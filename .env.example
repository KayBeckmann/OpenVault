# OpenVault — Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Ports ──────────────────────────────────────────────────────────────────────
# Port where the Flutter Web frontend is served (nginx)
FRONTEND_PORT=8081
# Port where the Dart/Shelf backend listens (internal, proxied by nginx in prod)
BACKEND_PORT=8090

# ── Security ───────────────────────────────────────────────────────────────────
# JWT signing secret — generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# AES-256 encryption key for vault data at rest — generate with: openssl rand -hex 32
# This key protects the encrypted vault files on disk.
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Argon2id cost parameter (number of iterations) — minimum 3, recommended 4-8
ARGON2_SALT_ROUNDS=3

# ── Git ────────────────────────────────────────────────────────────────────────
# Maximum size of a vault clone in MB (safety limit)
VAULT_MAX_SIZE_MB=500

# ── Server (optional overrides) ────────────────────────────────────────────────
# Absolute path for database file inside the container — default: /data/openvault.db
# DB_PATH=/data/openvault.db

# Absolute path for vault storage inside the container — default: /data/vaults
# VAULT_ROOT=/data/vaults
